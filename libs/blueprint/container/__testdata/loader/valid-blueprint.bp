version "2025-11-02"

variable instanceType: aws/ec2/instanceType {
    description = "The configuration buckets to create."
}

variable environment: string {}

value tableName: string {
    value = "${variables.environment}-ordersTable"
}

data network: aws/vpc {
    description = "Networking resources for the application."

    metadata {
        displayName = "Networking"
    }

    filter "tags" not contains "service"

    export vpcId as vpc: string {
        description = "The ID of the VPC."
    }
    export subnetIds: array {
        description = "The IDs of the subnets."
    }
}

resource ordersTable: aws/dynamodb/table {
    description = "Table that stores orders for an application."

    spec {
        tableName = "Orders"
    }
}

include coreInfra "core-infra.yaml" {
    description = "core infrastructure for the Orders API"

    metadata {
        sourceType = "aws/s3",
        bucket = "order-system-blueprints",
        region = "eu-west-1"
    }
}

export environment: string {
    field = variables.environment
    description = "The environment for the blueprint."
}

metadata {
    build = "esbuild"
}
