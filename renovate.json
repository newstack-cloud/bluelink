{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>newstack-cloud/renovate-config",
    "github>newstack-cloud/bluelink//renovate/bluelink-consumers"
  ],
  "packageRules": [
    {
      "description": "Per-component commit scope (so release-please attributes each go.mod bump to the right component in separate-pull-requests mode) and per-component grouping (so a component's simultaneous bumps land in one PR with no go.sum conflicts). Each component MUST use a unique groupName so groups never cross component boundaries.",
      "matchFileNames": ["libs/blueprint/**"],
      "semanticCommitScope": "blueprint",
      "groupName": "blueprint go modules"
    },
    {
      "matchFileNames": ["libs/blueprint-resolvers/**"],
      "semanticCommitScope": "blueprint-resolvers",
      "groupName": "blueprint-resolvers go modules"
    },
    {
      "matchFileNames": ["libs/blueprint-state/**"],
      "semanticCommitScope": "blueprint-state",
      "groupName": "blueprint-state go modules"
    },
    {
      "matchFileNames": ["libs/common/**"],
      "semanticCommitScope": "common",
      "groupName": "common go modules"
    },
    {
      "matchFileNames": ["libs/deploy-engine-client/**"],
      "semanticCommitScope": "deploy-engine-client",
      "groupName": "deploy-engine-client go modules"
    },
    {
      "matchFileNames": ["libs/plugin-framework/**"],
      "semanticCommitScope": "plugin-framework",
      "groupName": "plugin-framework go modules"
    },
    {
      "matchFileNames": ["apps/cli/**"],
      "semanticCommitScope": "cli",
      "groupName": "cli go modules"
    },
    {
      "matchFileNames": ["apps/deploy-engine/**"],
      "semanticCommitScope": "deploy-engine",
      "groupName": "deploy-engine go modules"
    },
    {
      "matchFileNames": ["tools/blueprint-ls/**"],
      "semanticCommitScope": "blueprint-ls",
      "groupName": "blueprint-ls go modules"
    },
    {
      "matchFileNames": ["tools/bluelink-manager/**"],
      "semanticCommitScope": "bluelink-manager",
      "groupName": "bluelink-manager go modules"
    },
    {
      "matchFileNames": ["tools/plugin-docgen/**"],
      "semanticCommitScope": "plugin-docgen",
      "groupName": "plugin-docgen go modules"
    },
    {
      "description": "plugin-docgen embeds core lib versions in a committed generated file (internal/env/versions.go) for logs/telemetry. Regenerate it whenever any internal Bluelink module bumps so it never goes stale. Requires a matching entry in RENOVATE_ALLOWED_COMMANDS on the runner.",
      "matchFileNames": ["tools/plugin-docgen/**"],
      "matchDatasources": ["go"],
      "matchPackageNames": ["/^github\\.com/newstack-cloud/bluelink//"],
      "postUpgradeTasks": {
        "commands": ["cd tools/plugin-docgen && go generate ./internal/env/..."],
        "fileFilters": ["tools/plugin-docgen/internal/env/versions.go"],
        "executionMode": "branch"
      }
    },
    {
      "description": "deploy-engine embeds core lib versions in a committed generated file (core/versions.go) for logs/telemetry, via the same genversions mechanism as plugin-docgen.",
      "matchFileNames": ["apps/deploy-engine/**"],
      "matchDatasources": ["go"],
      "matchPackageNames": ["/^github\\.com/newstack-cloud/bluelink//"],
      "postUpgradeTasks": {
        "commands": ["cd apps/deploy-engine && go generate ./core/..."],
        "fileFilters": ["apps/deploy-engine/core/versions.go"],
        "executionMode": "branch"
      }
    },
    {
      "description": "Docker base images for the deploy engine (mirror the deps(docker) convention). Own group so image bumps don't ride the deploy-engine go-modules PR.",
      "matchManagers": ["dockerfile"],
      "matchFileNames": ["apps/deploy-engine/**"],
      "semanticCommitScope": "docker",
      "groupName": "deploy-engine docker"
    }
  ]
}
